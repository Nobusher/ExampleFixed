<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:compilerservices="using:System.Runtime.CompilerServices"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:AvaloniaApplication2"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="using:AvaloniaApplication2.ViewModels"
             xmlns:vm = "using:AvaloniaApplication2.AvaloniaApplication2.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AvaloniaApplication2.GreetingView"
             x:DataType="viewmodels:GreetingViewModel">
 
    
   <StackPanel Margin="30" Spacing="16">
        <TextBlock Text="Say my name..." FontSize="14"/>
        <TextBox Text="{Binding Name}" Watermark="Нeisenberg?"/>
        <TextBlock Text="{Binding Greeting}" FontSize="18" FontWeight="SemiBold"/>
        <Button Content="Say it"
                Command="{Binding SayHelloCommand}"
                HorizontalAlignment="Left"/>
        <TextBlock Text="{Binding Message}"
                   FontSize="13"
                   IsVisible="{Binding Message,
                       Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
    </StackPanel>

</UserControl>
