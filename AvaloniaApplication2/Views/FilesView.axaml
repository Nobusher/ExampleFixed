<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="using:AvaloniaApplication2.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AvaloniaApplication2.FilesView"
             x:DataType="viewmodels:FilesViewModel">
<StackPanel Margin="30" Spacing="16">
	<TextBlock Text="File manager" 
               FontSize="18" FontWeight="SemiBold"/>
    <Button Content="Open file" Click="OpenFileButton_Click"
            HorizontalAlignment="Left"/>
    <TextBlock Text="{Binding FilePath}"
               FontSize="12"
               IsVisible="{Binding FilePath, 
               Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
    <TextBox Text="{Binding FileContent}"
             IsReadOnly="True"
             AcceptsReturn="True"
             Height="200"
             TextWrapping="Wrap"
             IsVisible="{Binding FileContent, 
             Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

</StackPanel>
</UserControl>
